{
  "skill": "MING",
  "version": "1.0",
  "output_format": "markdown_with_json_frontmatter",
  "required_files": [
    "soul.md",
    "memory.md",
    "interaction.md",
    "manifest.json",
    "meta.json"
  ],
  "optional_files": [
    "corrections.md",
    "conflicts.md",
    "proactive.json"
  ],
  "evidence_format": "（`{v|a|i}`，来源日期/来源简述）",
  "impression_separator": "---",
  "coverage_targets": {
    "cognition": {
      "v": 3,
      "a": 1
    },
    "expression": {
      "v": 5,
      "a": 1
    },
    "behavior": {
      "v": 2,
      "a": 3
    },
    "emotion": {
      "v": 2,
      "a": 1
    },
    "memory": {
      "v": 3
    },
    "boundary": {
      "v": 1
    }
  },
  "confidence_thresholds": {
    "high": "all dimensions meet coverage targets",
    "medium": "≥4 dimensions meet targets",
    "low": "<4 dimensions meet targets"
  },
  "conflict_policy": {
    "preservation": "numbered_preservation",
    "numbering": "C1, C2, C3...",
    "resolution_options": [
      "preserve_a",
      "preserve_b",
      "coexist",
      "user_decides"
    ],
    "impression_conflict": "never auto-resolve verbatim vs verbatim"
  },
  "snapshot_policy": {
    "max_snapshots": 20,
    "auto_cleanup": true,
    "safety_backup": "always before rollback",
    "files_included": [
      "soul.md",
      "memory.md",
      "interaction.md",
      "corrections.md",
      "conflicts.md",
      "SKILL.md",
      "manifest.json",
      "meta.json"
    ]
  }
}
